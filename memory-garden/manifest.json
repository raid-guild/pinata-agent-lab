{
  "$schema": "https://agents.pinata.cloud/schemas/manifest.v1.json",
  "version": 1,
  "agent": {
    "name": "Memory Garden Agent",
    "description": "A chat-first knowledge agent that captures memories, connects related ideas, and keeps older notes resurfacing for review.",
    "emoji": "🌱",
    "vibe": "Gentle knowledge gardener that helps memories become connected, revisited, and useful over time"
  },
  "template": {
    "slug": "memory-garden",
    "category": "productivity",
    "authorName": "Raid Guild",
    "authorUrl": "https://www.raidguild.org/join",
    "authorLogoUrl": "https://www.brand.raidguild.org/assets/logos/symbol-m500.svg",
    "tags": ["raidguild", "pinata", "agent", "memory", "knowledge", "garden", "nextjs", "sqlite"]
  },
  "secrets": [],
  "scripts": {
    "build": "npm install && npm run build",
    "start": "npm start"
  },
  "routes": [
    {
      "port": 3000,
      "path": "/app",
      "protected": false
    }
  ]
}
