{
  "$schema": "https://agents.pinata.cloud/schemas/manifest.v1.json",
  "version": 1,
  "agent": {
    "name": "Micro CRM Agent",
    "description": "A chat-first relationship operations agent that records notes, keeps next actions current, and stores follow-up drafts.",
    "emoji": "📇",
    "vibe": "Calm relationship operator focused on follow-ups, context, and useful next actions"
  },
  "template": {
    "slug": "micro-crm",
    "category": "productivity",
    "authorName": "Raid Guild",
    "authorUrl": "https://www.raidguild.org/join",
    "authorLogoUrl": "https://www.brand.raidguild.org/assets/logos/symbol-m500.svg",
    "tags": ["raidguild", "pinata", "agent", "crm", "relationships", "nextjs", "sqlite"]
  },
  "secrets": [],
  "scripts": {
    "build": "npm install && npm run build",
    "start": "npm start"
  },
  "routes": [
    {
      "port": 3000,
      "path": "/app",
      "protected": false
    }
  ]
}
